DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here

# OpenAI (required for all AI features)
OPENAI_API_KEY=your_openai_api_key_here

# Model selection (optional — defaults to gpt-3.5-turbo)
# AI_MODEL=gpt-3.5-turbo
# AI_MODEL_COMPLEX=gpt-4o-mini  # Used for long/complex queries, falls back to AI_MODEL

# Sleep mode (saves usage hours). Set both to 0 to disable.
SLEEP_START=1
SLEEP_END=7
SLEEP_TIMEZONE=0

# Google Custom Search Engine (for /search command)
# Get key: https://console.cloud.google.com → APIs → Custom Search API
# Get CX: https://programmablesearchengine.google.com/ → your search engine
GOOGLE_CSE_KEY=your_api_key_here
GOOGLE_CSE_CX=your_search_engine_id_here
